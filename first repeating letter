
function firstRepeating(str) {
    const map = new Map();

    for (let i = 0; i < str.length; i++) {
        if (map.has(str[i])) {
            return `First repeating character at index ${i}`;
        }
        map.set(str[i], i);
    }

    return 'No repeating item!!';
}

console.log(firstRepeating('ccoodding'));
