/**
 * @param {number[]} height
 * @return {number}
 */
var maxArea = function(height) {
    let left=0;
    let right=height.length-1;

    let ans=0;

    while(left<right){
        let min=Math.min(height[left],height[right]) * (right-left);
        if(ans<min){
            ans=min;
        }

        if(height[left]<height[right]){
            left++;
        }else{
            right--;
        }
        
    }

    return ans;
    
};
