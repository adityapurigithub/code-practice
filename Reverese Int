/**
 * @param {number} x
 * @return {number}
 */
var reverse = function(x) {
    const MAX = 2**31 - 1;
    const MIN = -(2**31);

    

    let sign = x < 0 ? -1 : 1;
    let rev = parseInt(Math.abs(x).toString().split('').reverse().join(''));

    rev = rev * sign;

    if (rev > MAX || rev < MIN) return 0;
    return rev;
};
