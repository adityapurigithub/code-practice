
var mergeTwoLists = function(arr1, arr2) {

    let res=[];
    
    let i=0,j=0;
    
    while(i<arr1.length && j<arr2.length){
      
      if(arr1[i]<arr2[j]){
        res.push(arr1[i]);
        i++;
      }else{
        res.push(arr2[j]);
        j++
      }
      
    }
    
    while(i<arr1.length){
      res.push(arr1[i]);
      i++;
    }
    
    
    while(j<arr2.length){
      res.push(arr2[j]);
      j++;
    }
    
    return res;
};

console.log(mergeTwoLists([1,2,3],[1,3,4]));
